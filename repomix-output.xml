				backgroundColor: 'rgba(255, 255, 255, 0.65)',
				backdropFilter: 'blur(20px) saturate(150%)',
				border: '1px solid rgba(255, 255, 255, 0.5)',
				boxShadow: '0 20px 40px rgba(93, 64, 55, 0.08)', // 阴影颜色调暖
