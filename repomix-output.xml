  // 处理注销
  const handleLogout = async () => {
    await logout();
  };

  return (
    <>
      {/* --- 顶栏 (AppBar) --- */}
      <AppBar 
        position="sticky" 
        elevation={0}
        sx={{
          backgroundColor: 'rgba(255, 253, 245, 0.8)', // 玻璃拟态背景
