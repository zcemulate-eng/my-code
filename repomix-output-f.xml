'use client';
import React, { useState } from 'react';
import { 
    Container, Paper, TextField, Button, Typography, Box, Alert, Snackbar, 
    Link as MuiLink, Stack, InputAdornment, Grid 
} from '@mui/material';
import Link from 'next/link';
