// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  name         String?  
  email        String   @unique
  password     String
  phone        String?  
  dob          String?  
  address      String?  
  gender       String?  // 👉 补充：性别
  avatarUrl    String?  @db.LongText  // 存储用户头像路径
  isFirstLogin Boolean  @default(true) // 核心：标记是否为首次登录
  role         String   @default("User")
  status       String   @default("Active")
  createdAt    DateTime @default(now())
}

model Company {
  // 字段定义：左边是驼峰(代码用)，右边是映射(数据库用)
  id            Int      @id @default(autoincrement())
  
  companyCode   String   @unique @map("company_code") // 对应 SQL: company_code
  name          String   @map("company_name")         // 对应 SQL: company_name
  level         Int      // 对应 SQL: level (INT)
  country       String?  // 对应 SQL: country (可能为空)
  city          String?  // 对应 SQL: city
  foundedYear   Int?     @map("founded_year")         // 对应 SQL: founded_year
  annualRevenue BigInt?  @map("annual_revenue")       // 对应 SQL: annual_revenue (BIGINT)
  employees     Int?     // 对应 SQL: employees
  createdAt     DateTime @default(now()) @map("created_at")

  // 表名映射：代码里叫 Company (单数)，数据库里叫 companies (复数)
  @@map("companies")
}
</file>

